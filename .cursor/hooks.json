{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "python3 .cursor/hooks/nbconvert_on_ipynb_edit.py",
        "matcher": "\\.ipynb$",
        "timeout": 120
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python3 .cursor/hooks/pip_install_gate.py",
        "matcher": "pip3?\\s+install|python3?\\s+-m\\s+pip\\s+install|%pip\\s+install|!pip3?\\s+install",
        "timeout": 150
      }
    ],
    "beforeFileEdit": [
      {
        "command": "python3 .cursor/hooks/pip_install_gate.py",
        "matcher": "\\.ipynb$",
        "timeout": 150
      }
    ],
    "stop": [
      {
        "command": "python3 .cursor/hooks/pip_install_gate.py",
        "timeout": 10
      }
    ]
  }
}
